@startuml
left to right direction
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #FFF7ED
  BorderColor #9A5B38
  ArrowColor #4B5563
  FontColor #2F241F
}

actor Customer
actor Administrator as Admin

rectangle "Coffee Shop Customer Service System" {
  package "Customer Services" {
    usecase "Manage Account" as UC_Account
    usecase "Register / Log In" as UC_Login
    usecase "Update Profile" as UC_Profile

    usecase "Browse & Search Menu" as UC_Browse
    usecase "View Product Details" as UC_Details
    usecase "Manage Shopping Cart" as UC_Cart
    usecase "Place Order" as UC_Order
    usecase "Choose Delivery or Pickup" as UC_Fulfillment
    usecase "Apply Promotion" as UC_Promo
    usecase "Make Payment" as UC_Payment

    usecase "Track Order & View History" as UC_Track
    usecase "Submit Product Review" as UC_Review

    usecase "Interact with Gemini Chatbot" as UC_Chat
    usecase "Ask Menu Questions" as UC_Ask
    usecase "Get Recommendations" as UC_Recommend
  }

  package "Administration" {
    usecase "Manage Orders" as UA_Orders
    usecase "Manage Products" as UA_Products
    usecase "Manage Customers" as UA_Customers
    usecase "View Sales Analytics" as UA_Analytics
    usecase "Export Revenue Report" as UA_Export
  }
}

Customer --> UC_Account
Customer --> UC_Browse
Customer --> UC_Cart
Customer --> UC_Order
Customer --> UC_Track
Customer --> UC_Chat

UC_Account .> UC_Login : <<include>>
UC_Profile .> UC_Account : <<extend>>
UC_Details .> UC_Browse : <<extend>>

UC_Order .> UC_Cart : <<extend>>
UC_Order .> UC_Fulfillment : <<include>>
UC_Order .> UC_Payment : <<include>>
UC_Promo .> UC_Order : <<extend>>

UC_Review .> UC_Track : <<extend>>

UC_Ask .> UC_Chat : <<extend>>
UC_Recommend .> UC_Chat : <<extend>>

Admin --> UA_Orders
Admin --> UA_Products
Admin --> UA_Customers
Admin --> UA_Analytics
UA_Export .> UA_Analytics : <<extend>>
@enduml
